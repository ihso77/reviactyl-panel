generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  username          String    @unique
  name              String?
  password          String
  isAdmin           Boolean   @default(false)
  language          String    @default("en")
  twoFactorEnabled  Boolean   @default(false)
  twoFactorSecret   String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  servers           Server[]
  apiKeys           ApiKey[]
  sshKeys           SshKey[]
  activityLogs      ActivityLog[]
}

model Node {
  id          String   @id @default(cuid())
  name        String   @unique
  location    String
  fqdn        String?
  scheme      String   @default("https")
  port        Int      @default(443)
  cpu         Float    @default(0)
  memory      Float    @default(0)
  disk        Float    @default(0)
  status      String   @default("offline")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  servers     Server[]
}

model Server {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("offline")
  nodeId      String
  category    String?
  egg         String?
  cpu         Float    @default(0)
  memory      Int      @default(0)
  memoryLimit Int      @default(1024)
  disk        Int      @default(0)
  diskLimit   Int      @default(10240)
  networkIn   Float    @default(0)
  networkOut  Float    @default(0)
  players     Int      @default(0)
  maxPlayers  Int      @default(20)
  ip          String?
  port        Int      @default(25565)
  suspended   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  node        Node     @relation(fields: [nodeId], references: [id])
  owner       User     @relation(fields: [ownerId], references: [id])
  ownerId     String
  databases   ServerDatabase[]
  backups     Backup[]
  schedules   Schedule[]
}

model ServerDatabase {
  id          String   @id @default(cuid())
  name        String
  host        String   @default("localhost")
  port        Int      @default(3306)
  username    String
  password    String?
  connections Int      @default(0)
  serverId    String
  server      Server   @relation(fields: [serverId], references: [id])
  createdAt   DateTime @default(now())
}

model Backup {
  id          String   @id @default(cuid())
  name        String
  size        String?
  status      String   @default("completed")
  serverId    String
  server      Server   @relation(fields: [serverId], references: [id])
  createdAt   DateTime @default(now())
}

model Schedule {
  id          String   @id @default(cuid())
  name        String
  cron        String
  lastRun     DateTime?
  nextRun     DateTime?
  isActive    Boolean   @default(true)
  serverId    String
  server      Server   @relation(fields: [serverId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ApiKey {
  id          String    @id @default(cuid())
  identifier  String    @unique
  description String?
  allowedIps  String    @default("*")
  token       String    @unique
  lastUsedAt  DateTime?
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  createdAt   DateTime  @default(now())
}

model SshKey {
  id          String  @id @default(cuid())
  name        String
  publicKey   String
  fingerprint String
  userId      String
  user        User    @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}

model ActivityLog {
  id          String   @id @default(cuid())
  action      String
  description String
  ip          String?
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}
